---
import { sanitizeViewTransitionName } from "../utils/sanitizeViewTransitionName";

interface Props {
  title: string;
  subtitle?: string;
  authors?: string[];
  releaseDate?: number | string;
}

const { title, subtitle, authors, releaseDate } = Astro.props;
const transitionName = sanitizeViewTransitionName(title);

const authorParts: string[] = [];
if (authors?.length) {
  const last = authors.length - 1;
  authors.forEach((a, i) => {
    authorParts.push(a.trim());
    if (i < last - 1) authorParts.push(", ");
    else if (i === last - 1) authorParts.push(" und ");
  });
}
if (authorParts.length && releaseDate) authorParts.push(`, ${releaseDate}`);
else if (releaseDate) authorParts.push(String(releaseDate));
const authorsLine = authorParts.join("");
---

<div class="book-heading">
  <h1
    class="text-pretty"
    style=`view-transition-name: --header-${transitionName};`
    data-testid="heading-book"
  >
    {title}
  </h1>
  {subtitle && <p class="subtitle"
    style=`view-transition-name: --subheader-${transitionName};`
  >{subtitle}</p>}
  {authorsLine && <div class="authors" style=`view-transition-name: --author-${transitionName};` set:html={authorsLine} />}
</div>

<style>
  h1 {
    font-weight: 400;
    margin-top: 4rem;
    margin-bottom: min(2.5cqw, 1rem);
    font-size: 3.2rem;
    line-height: 1;
  }

  .subtitle {
    font-style: italic;
    font-size: 1.8rem;
    display: block;
    line-height: 1;
    &:before {
      display: none;
    }
  }

  .book-heading {
    margin-bottom: min(10cqw, 4rem);
  }

  div.authors {
    display: inline;
    margin-top: calc(var(--heading-margin-bottom) * -1.01);
    margin-bottom: calc(var(--heading-margin-bottom) - 1ch);
    padding: 0px;
    color: var(--color-foreground-subtle);
    font-size: 1.1rem;
  }
</style>
