---
import type { CollectionEntry } from "astro:content";
import BookHeading from "./BookHeading.astro";
import FormattedDate from "./FormattedDate.astro";
import Webmentions from "./Webmentions";

type Props = CollectionEntry<"book" | "blog">["data"] & {
  pubDate?: Date;
  updatedDate?: Date;
  author?: string;
  url?: string;
  syndication?: Array<{ name: string; url: string }>;
};

const { pubDate, updatedDate, author = "Konstantin", url, syndication } = Astro.props;
---

<div class="container" data-testid="article-container">
  <article class="h-entry">
    <section>
      <BookHeading {...Astro.props} />

      <!-- Microformat metadata -->
      <div class="article-meta">
        {author && (
          <span class="p-author h-card">
            <a class="p-name u-url" href="/">{author}</a>
          </span>
        )}
        {pubDate && (
          <time class="dt-published" datetime={pubDate.toISOString()}>
            <FormattedDate date={pubDate} />
          </time>
        )}
        {updatedDate && (
          <time class="dt-updated" datetime={updatedDate.toISOString()}>
            (updated: <FormattedDate date={updatedDate} />)
          </time>
        )}
        {url && <a class="u-url" href={url} style="display:none;">{url}</a>}
      </div>

      {syndication && syndication.length > 0 && (
        <div class="syndication-links">
          <span>Also on:</span>
          {syndication.map((link) => (
            <a href={link.url} class="u-syndication" rel="syndication">
              {link.name}
            </a>
          ))}
        </div>
      )}

      <div class="e-content" style="view-transition-name: --article-content;">
        <slot />
      </div>

      {url && <Webmentions url={url} client:load />}
    </section>
  </article>
</div>

<script>
  const footnotesSection = document.querySelector("section.footnotes");
  const noteEntries = document.querySelectorAll("section.footnotes>ol>li");

  document
    .querySelectorAll(".data-footnote-backref")
    .forEach((e) => e.remove());

  for (const { id, children } of noteEntries) {
    const isMarginNote = id
      .replace("user-content-fn-", "")
      .trim()
      .startsWith("mn-");

    const replacementLabel = document.createElement("label");
    replacementLabel.htmlFor = id;
    replacementLabel.classList.add("margin-toggle");
    if (!isMarginNote) {
      replacementLabel.classList.add("sidenote-number");
    }

    const replacementCheckbox = document.createElement("input");
    replacementCheckbox.type = "checkbox";
    replacementCheckbox.id = id;
    replacementCheckbox.name = id;
    replacementCheckbox.classList.add("margin-toggle");

    const replacementEntry = document.createElement("span");
    replacementEntry.classList.add(isMarginNote ? "marginnote" : "sidenote");
    replacementEntry.append(...children[0].childNodes);

    const originalNoteReferenceMark = document.querySelector(
      "sup:has(a[href='#" + id + "'])",
    );
    originalNoteReferenceMark?.replaceWith(
      replacementLabel,
      replacementCheckbox,
      replacementEntry,
    );

    footnotesSection?.remove();
  }
</script>

<style is:global>
  .container {
    container-type: inline-size;
    &:not(:has(.margin-toggle)) {
      contain: width;
      margin: 0 auto 2em;
    }
    &:has(.margin-toggle) {
      max-width: 900px;
    }

    /* Tufte CSS styles */
    @container (min-width: 0px) {
      article {
        display: block;
        width: 100%;
        &:not(:has(.margin-toggle)) {
          margin: auto;
          padding-left: 0;
        }
        padding: 2rem 0;
        color: var(--color-foreground, #111);
        max-width: 1400px;
        counter-reset: sidenote-counter;

        h2 {
          font-style: italic;
          font-weight: 400;
          margin-top: 2.1rem;
          margin-bottom: 1.4rem;
          font-size: 2.2rem;
          line-height: 1;
        }

        h3 {
          font-style: italic;
          font-weight: 400;
          font-size: 1.7rem;
          margin-top: 2rem;
          margin-bottom: 1.4rem;
          line-height: 1;
        }

        hr {
          display: block;
          height: 1px;
          width: 55%;
          border: 0;
          border-top: 1px solid #ccc;
          margin: 1em 0;
          padding: 0;
        }

        .numeral {
          font-family: "Tinos NF", serif;
        }

        .danger {
          color: var(--color-error);
        }

        p,
        dl,
        ol,
        ul {
          font-size: 1.4rem;
          line-height: 2rem;
        }

        ol,
        ul,
        dl {
          margin: 1rem 0;
        }

        ul {
          list-style: square;
        }

        ol {
          list-style: upper-roman;
        }

        p {
          padding-right: 0;
          text-align: justify;
          vertical-align: baseline;
          &:before {
            content: "\0000a0";
            margin-right: 2ch;
          }
        }

        /* Chapter Epigraphs */
        div.epigraph {
          margin: 5em 0;
        }

        div.epigraph > blockquote {
          margin: 3em 0;
        }

        div.epigraph > blockquote,
        div.epigraph > blockquote > p {
          font-style: italic;
        }

        div.epigraph > blockquote > footer {
          font-style: normal;
        }

        div.epigraph > blockquote > footer > cite {
          font-style: italic;
        }
        /* end chapter epigraphs styles */

        blockquote {
          margin: 2rem 1rem;
          padding-left: 1rem;
          font-size: 1.4rem;
          border-left: 2px solid var(--color-foreground-subtle);
        }

        blockquote p {
          width: 86%;
        }

        blockquote footer {
          width: 86%;
          font-size: 1.1rem;
          text-align: right;
        }

        section > p,
        section > footer,
        section > table {
          width: 100%;
        }

        &:not(:has(.margin-toggle)) section {
          columns: 2 35ch;
          column-gap: 3rem;

          & > * {
            max-width: 69ch;
          }

          & > .book-heading {
            column-span: all;
          }
        }

        &:has(.margin-toggle) section > p,
        &:has(.margin-toggle) section > footer,
        &:has(.margin-toggle) section > table {
          max-width: 69ch;
        }

        &:has(.margin-toggle) {
          section > p,
          section > footer,
          section > table {
            width: 75%;
          }
        }

        /* 50 + 5 == 55, to be the same width as paragraph */
        section > dl,
        section > ol,
        section > ul {
          width: 70%;
          -webkit-padding-start: 5%;
        }

        dt:not(:first-child),
        li:not(:first-child) {
          margin-top: 0.25rem;
        }

        figure {
          padding: 0;
          border: 0;
          font-size: 100%;
          font: inherit;
          vertical-align: baseline;
          max-width: 55%;
          -webkit-margin-start: 0;
          -webkit-margin-end: 0;
          margin: 0 0 3em 0;
        }

        figcaption {
          float: right;
          clear: right;
          margin-top: 0;
          margin-bottom: 0;
          font-size: 1.1rem;
          line-height: 1.6;
          vertical-align: baseline;
          position: relative;
          max-width: 40%;
        }

        figure.fullwidth figcaption {
          margin-right: 24%;
        }

        a,
        a:link,
        a:visited {
          text-decoration: underline;
          color: inherit;
          text-underline-offset: 0.1em;
          text-decoration-thickness: 0.05em;
        }

        /* Sidenotes, margin notes, figures, captions */
        img {
          margin-top: 48px;
          max-width: 100%;
        }

        .sidenote,
        .marginnote {
          float: right;
          clear: right;
          margin-right: -30%;
          width: 26%;
          margin-top: 0.3rem;
          margin-bottom: 0;
          font-size: 1.1rem;
          line-height: 1.3;
          vertical-align: baseline;
          text-align: start;
          position: relative;

          & img {
            margin-top: 0;
          }
        }

        .sidenote-number {
          counter-increment: sidenote-counter;
        }

        .sidenote-number:after,
        .sidenote:before {
          position: relative;
          vertical-align: baseline;
        }

        .sidenote-number:after {
          content: counter(sidenote-counter);
          font-size: 1rem;
          top: -0.5rem;
          left: 0.1rem;
        }

        .sidenote:before {
          content: counter(sidenote-counter) " ";
          font-size: 1rem;
          top: -0.5rem;
        }

        blockquote .sidenote,
        blockquote .marginnote {
          margin-right: -82%;
          min-width: 59%;
          text-align: left;
        }

        div.fullwidth,
        table.fullwidth {
          width: 100%;
        }

        div.table-wrapper {
          overflow-x: auto;
          font-family: "Trebuchet MS", "Gill Sans", "Gill Sans MT", sans-serif;
        }

        .sans {
          font-family: "Gill Sans", "Gill Sans MT", Calibri, sans-serif;
          letter-spacing: 0.03em;
        }

        code,
        pre > code {
          font-family: Consolas, "Liberation Mono", Menlo, Courier, monospace;
          font-size: 1rem;
          line-height: 1.42;
          -webkit-text-size-adjust: 100%; /* Prevent adjustments of font size after orientation changes in iOS. See https://github.com/edwardtufte/tufte-css/issues/81#issuecomment-261953409 */
        }

        .sans > code {
          font-size: 1.2rem;
        }

        h1 > code,
        h2 > code,
        h3 > code {
          font-size: 0.8em;
        }

        .marginnote > code,
        .sidenote > code {
          font-size: 1rem;
        }

        pre > code {
          font-size: 0.9rem;
          width: 52.5%;
          margin-left: 2.5%;
          overflow-x: auto;
          display: block;
        }

        pre.fullwidth > code {
          width: 90%;
        }

        .fullwidth {
          max-width: 90%;
          clear: both;
        }

        span.newthought {
          font-variant: small-caps;
          font-size: 1.2em;
        }

        input.margin-toggle {
          display: none;
        }

        label.sidenote-number {
          display: inline-block;
          max-height: 2rem; /* should be less than or equal to paragraph line-height */
        }

        label.margin-toggle:not(.sidenote-number) {
          display: none;
        }

        .iframe-wrapper {
          position: relative;
          padding-bottom: 56.25%; /* 16:9 */
          padding-top: 25px;
          height: 0;
        }

        .iframe-wrapper iframe {
          position: absolute;
          top: 0;
          left: 0;
          width: 100%;
          height: 100%;
        }
      }
    }

    @container (max-width: 1240px) {
      article {
        width: 90%;
        padding: 1svw 3svw;
      }
    }

    @container (max-width: 760px) {
      article {
        width: 94%;
        margin: 0 1vw;
        padding-right: 0;
        hr,
        section > p,
        section > footer,
        section > table {
          width: 100%;
        }
        &:has(.margin-toggle) {
          section > p,
          section > footer,
          section > table {
            width: 100%;
          }
        }

        pre > code {
          width: 97%;
        }

        section > dl,
        section > ol,
        section > ul {
          width: 90%;
        }

        figure {
          max-width: 90%;
        }

        figcaption,
        figure.fullwidth figcaption {
          margin-right: 0%;
          max-width: none;
        }

        blockquote {
          margin-left: 1.5em;
          margin-right: 0em;
        }

        blockquote p,
        blockquote footer {
          width: 90%;
        }

        label.margin-toggle:not(.sidenote-number) {
          display: inline;
          &:before {
            display: inline-block;
            content: "\21A9";
          }
        }

        .sidenote,
        .marginnote {
          display: none;
        }

        .margin-toggle:checked + .sidenote,
        .margin-toggle:checked + .marginnote {
          display: block;
          float: left;
          left: 1rem;
          clear: both;
          width: 95%;
          margin: 1rem 2.5%;
          position: relative;
        }

        label {
          cursor: pointer;
        }

        div.table-wrapper,
        table {
          width: 85%;
        }

        img {
          width: 100%;
        }
      }
    }
  }

  .article-meta {
    font-size: 1.1rem;
    color: var(--color-foreground-subtle);
    margin-bottom: 2rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .article-meta time,
  .article-meta .p-author {
    display: inline;
  }

  .article-meta .p-author a {
    text-decoration: none;
  }

  .syndication-links {
    font-size: 1.1rem;
    color: var(--color-foreground-subtle);
    margin-bottom: 2rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .syndication-links a {
    text-decoration: underline;
    color: var(--color-foreground-subtle);
    text-underline-offset: 0.2em;
  }

  .syndication-links a:hover {
    color: var(--color-foreground);
  }

  /* Webmentions styles */
  :global(.webmentions) {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-foreground-subtle);
  }

  :global(.webmentions h3) {
    font-size: 2rem;
    margin-bottom: 1.5rem;
    font-style: italic;
  }

  :global(.webmention-section) {
    margin-bottom: 2rem;
  }

  :global(.webmention-section h4) {
    font-size: 1.4rem;
    margin-bottom: 1rem;
    color: var(--color-foreground-subtle);
  }

  :global(.webmention-faces) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  :global(.webmention-face) {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-foreground-subtle);
    color: var(--color-background);
    font-weight: bold;
    text-decoration: none;
  }

  :global(.webmention-face img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    margin: 0;
  }

  :global(.webmention-replies) {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  :global(.webmention-reply) {
    padding: 1rem;
    border: 1px solid var(--color-foreground-subtle);
    border-radius: 0.5rem;
  }

  :global(.webmention-reply-author) {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  :global(.webmention-reply-author img) {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    margin: 0;
  }

  :global(.webmention-reply-author a) {
    font-weight: bold;
    text-decoration: none;
  }

  :global(.webmention-reply-author time) {
    font-size: 0.9rem;
    color: var(--color-foreground-subtle);
    display: block;
  }

  :global(.webmention-reply-content) {
    font-size: 1.2rem;
    line-height: 1.6;
  }
</style>
