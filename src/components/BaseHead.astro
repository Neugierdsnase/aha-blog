---
import { join } from "node:path";
import { AstroFont } from "astro-font";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import "../styles/app.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: "website" | "article" | "book";
  pubDate?: Date;
  updatedDate?: Date;
  author?: string;
  lang?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
  title,
  description = SITE_DESCRIPTION,
  image,
  type = "website",
  pubDate,
  updatedDate,
  author = "Konstantin",
  lang = "de",
} = Astro.props;

// Structured data for SEO
const structuredData = {
  "@context": "https://schema.org",
  "@type": type === "article" ? "BlogPosting" : type === "book" ? "Review" : "WebSite",
  headline: title,
  description: description,
  url: canonicalURL.toString(),
  ...(type === "article" && pubDate && {
    datePublished: pubDate.toISOString(),
    ...(updatedDate && { dateModified: updatedDate.toISOString() }),
    author: {
      "@type": "Person",
      name: author,
    },
  }),
  ...(image && { image: new URL(image, Astro.url).toString() }),
};
---

<head>
  <!-- Font loading -->
  <AstroFont
    config={[
      {
        name: "Tinos NF",
        preload: true,
        display: "swap",
        selector: "body",
        fallback: "serif",
        src: [
          {
            path: join(
              process.cwd(),
              "public",
              "Tinos",
              "TinosNerdFont-Regular.ttf",
            ),
            style: "normal",
            weight: "normal",
          },
          {
            path: join(
              process.cwd(),
              "public",
              "Tinos",
              "TinosNerdFont-Italic.ttf",
            ),
            style: "italic",
            weight: "normal",
          },
          {
            path: join(
              process.cwd(),
              "public",
              "Tinos",
              "TinosNerdFont-Bold.ttf",
            ),
            style: "normal",
            weight: "bold",
          },
          {
            path: join(
              process.cwd(),
              "public",
              "Tinos",
              "TinosNerdFont-BoldItalic.ttf",
            ),
            style: "italic",
            weight: "bold",
          },
        ],
      },
      {
        name: "Galnoy",
        preload: true,
        display: "swap",
        fallback: "serif",
        src: [
          {
            path: join(process.cwd(), "public", "Galnoy-MediumText.otf"),
            style: "normal",
            weight: "normal",
          },
          {
            path: join(process.cwd(), "public", "Galnoy-BoldHeadline.otf"),
            style: "normal",
            weight: "bold",
          },
          {
            path: join(process.cwd(), "public", "Galnoy-LightHeadline.otf"),
            style: "normal",
            weight: "light",
          },
        ],
      },
      {
        name: "Soria",
        preload: true,
        display: "swap",
        selector: "h1",
        fallback: "serif",
        src: [
          {
            path: join(process.cwd(), "public", "Soria.ttf"),
            style: "normal",
            weight: "bold",
          },
        ],
      },
    ]}
  />

  <!-- Global Metadata -->
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <meta name="generator" content={Astro.generator} />
  <meta name="robots" content="index, follow" />
  <meta name="author" content={author} />

  <!-- Canonical URL -->
  <link rel="canonical" href={canonicalURL} />

  <!-- Primary Meta Tags -->
  <title>{title}</title>
  <meta name="title" content={title} />
  <meta name="description" content={description} />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content={type} />
  <meta property="og:url" content={Astro.url} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:site_name" content={SITE_TITLE} />
  <meta property="og:locale" content={lang === "de" ? "de_DE" : "en_US"} />
  {image && <meta property="og:image" content={new URL(image, Astro.url)} />}
  {
    type === "article" && pubDate && (
      <meta property="article:published_time" content={pubDate.toISOString()} />
    )
  }
  {
    type === "article" && updatedDate && (
      <meta
        property="article:modified_time"
        content={updatedDate.toISOString()}
      />
    )
  }
  {type === "article" && <meta property="article:author" content={author} />}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content={Astro.url} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  {
    image && (
      <meta name="twitter:image" content={new URL(image, Astro.url)} />
    )
  }

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <slot />
</head>
