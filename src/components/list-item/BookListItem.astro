---
import type { BookPostType } from "../../pages/book/[...slug].astro";
import { genreLabels } from "../../utils/genreLabels";
import { sanitizeViewTransitionName } from "../../utils/sanitizeViewTransitionName";

type Props = BookPostType;

const { id, data } = Astro.props;
const { title, subtitle, authors, releaseDate, genre, rating } = data;

const transitionName = sanitizeViewTransitionName(title);
---

<li class="list-none">
  <a href={"/book/" + id} class="link">
    <span class="ornament" aria-hidden="true"></span>
    <span
      class="font-display text-lg line-clamp-1 col-span-2"
      style=`view-transition-name: --header-${transitionName};`
      >{title}</span
    >
    {subtitle && (
      <span
        class="font-galnoy italic text-sm text-foreground-subtle line-clamp-1 col-span-2 mt-0.5"
        style=`view-transition-name: --subheader-${transitionName};`
        >{subtitle}</span
      >
    )}
    <span class="text-xs text-foreground-subtle mt-2 flex items-center gap-2 overflow-hidden whitespace-nowrap text-ellipsis col-span-2">
      <span class="font-serif">{authors.join(", ")}</span>
      <span class="text-surface-high" aria-hidden="true">&middot;</span>
      <span>{releaseDate}</span>
      {rating != null && (
        <>
          <span class="text-surface-high" aria-hidden="true">&middot;</span>
          <span class="font-old tabular-nums">{rating}/10</span>
        </>
      )}
    </span>
    <span class="genre">{genreLabels[genre.primary] ?? genre.primary.replace("-", " ")}</span>
  </a>
</li>

<style>
  @reference "../../styles/app.css";

  .link {
    @apply relative block px-6 py-5 bg-background text-foreground no-underline border-foreground/10 border
      overflow-hidden transition-all duration-500;
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto auto auto;
    gap: 0;

    &::before {
      content: "";
      @apply absolute inset-0 bg-linear-to-r from-surface-high/0 via-surface-high/10 to-surface-high/0
        opacity-0 transition-opacity duration-500;
    }

    &:hover::before,
    &:focus-visible::before {
      @apply opacity-100;
    }

    &:hover,
    &:focus-visible {
      @apply pl-8;

      & .ornament {
        @apply opacity-100 left-2;
      }
    }

    &:focus-visible {
      @apply outline-2 -outline-offset-2 outline-foreground/30;
    }
  }

  .ornament {
    @apply absolute left-0 top-1/2 -translate-y-1/2 opacity-0
      transition-all duration-500 text-surface-high text-sm;

    &::before {
      content: "✦";
    }
  }

  .genre {
    @apply text-xxs text-foreground-subtle/70 uppercase tracking-widest
      row-start-4 col-start-2 mt-1 self-end text-right;
    font-variant: small-caps;
  }
</style>
