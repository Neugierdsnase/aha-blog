---
import BaseHead from "../components/BaseHead.astro";
import { GOATCOUNTER_URL } from "../consts";

type Props = {
  lang: "de" | "en";
  title: string;
  description?: string;
};

const pages: { label: string; href: string }[] = [
  { label: "Über mich", href: "/about" },
  { label: "Jüngst gelesen", href: "/book" },
  { label: "Jüngst geschrieben", href: "/blog" },
  { label: "RSS", href: "/rss.xml" },
];

const currentPath = Astro.url.pathname;
const { lang, title, description } = Astro.props;

const isActive = (href: string) =>
  currentPath.startsWith(href) && href !== "/rss.xml";

const navLineBase =
  "[stroke:var(--color-foreground)] [stroke-width:2] [stroke-linecap:round] origin-center [transition:transform_0.4s_cubic-bezier(0.34,1.56,0.64,1),opacity_0.3s_ease] group-[.is-open]/toggle:[stroke:var(--color-background)]";
---

<!doctype html>
<html lang={lang}>
  <BaseHead title={title + " vom Konstantin"} description={description} />

  <body class="text-foreground">
    <!-- Mobile nav toggle -->
    <button
      id="nav-toggle"
      class="group/toggle fixed top-4 right-4 z-[100] bg-surface border border-foreground rounded-full size-12 flex items-center justify-center cursor-pointer desktop:!hidden shadow-[0_2px_8px_rgb(0_0_0/0.1)] [transition:transform_0.4s_cubic-bezier(0.34,1.56,0.64,1),box-shadow_0.4s_ease,background-color_0.3s_ease] hover:scale-[1.08] hover:shadow-[0_4px_16px_rgb(0_0_0/0.15)] [&.is-open]:bg-foreground"
      aria-label="Navigation öffnen"
      aria-expanded="false"
    >
      <svg viewBox="0 0 32 32" width="32" height="32">
        <line
          class:list={[navLineBase, "group-[.is-open]/toggle:translate-y-[7px] group-[.is-open]/toggle:rotate-45"]}
          x1="6" y1="9" x2="26" y2="9"
        />
        <line
          class:list={[navLineBase, "group-[.is-open]/toggle:opacity-0 group-[.is-open]/toggle:scale-x-0"]}
          x1="6" y1="16" x2="26" y2="16"
        />
        <line
          class:list={[navLineBase, "group-[.is-open]/toggle:-translate-y-[7px] group-[.is-open]/toggle:-rotate-45"]}
          x1="6" y1="23" x2="26" y2="23"
        />
      </svg>
    </button>

    <!-- Mobile overlay nav -->
    <div
      id="nav-overlay"
      class="group/overlay desktop:hidden fixed inset-0 z-[90] pointer-events-none [&.is-open]:pointer-events-auto"
      aria-hidden="true"
    >
      <div
        id="nav-backdrop"
        class="absolute inset-0 bg-foreground opacity-0 transition-opacity duration-500 group-[.is-open]/overlay:opacity-40"
      ></div>
      <nav
        class="absolute top-0 right-0 w-[min(85vw,380px)] h-full bg-surface pt-20 px-10 pb-10 flex flex-col translate-x-full [transition:transform_0.5s_cubic-bezier(0.22,1,0.36,1)] shadow-[-8px_0_32px_rgb(0_0_0/0.15)] overflow-y-auto group-[.is-open]/overlay:translate-x-0"
      >
        <p
          class="font-galnoy font-bold text-3xl mb-8 opacity-0 -translate-y-2.5 [transition:opacity_0.4s_ease_0.2s,transform_0.4s_ease_0.2s] group-[.is-open]/overlay:opacity-100 group-[.is-open]/overlay:translate-y-0"
        >
          Konstantin Kovar
        </p>
        <ul class="list-none p-0 m-0 flex flex-col gap-1">
          {
            pages.map(({ label, href }, i) => (
              <li
                class="opacity-0 translate-x-[30px] [transition:opacity_0.4s_ease_var(--delay),transform_0.4s_ease_var(--delay)] group-[.is-open]/overlay:opacity-100 group-[.is-open]/overlay:translate-x-0"
                style={`--delay: ${i * 80 + 120}ms`}
              >
                <a
                  href={href}
                  data-active={isActive(href) || undefined}
                  class="group/mlink block font-galnoy text-lg text-foreground no-underline py-3 px-4 rounded [transition:background-color_0.3s_ease,padding-left_0.4s_cubic-bezier(0.34,1.56,0.64,1)] hover:bg-background hover:pl-6 focus-visible:bg-background focus-visible:pl-6 data-[active]:bg-background"
                >
                  <span
                    class="inline-block mr-2 opacity-0 scale-50 -rotate-90 [transition:opacity_0.3s_ease,transform_0.4s_cubic-bezier(0.34,1.56,0.64,1)] text-cherry-blossom-pink group-hover/mlink:opacity-100 group-hover/mlink:scale-100 group-hover/mlink:rotate-0 group-focus-visible/mlink:opacity-100 group-focus-visible/mlink:scale-100 group-focus-visible/mlink:rotate-0 group-data-[active]/mlink:opacity-100 group-data-[active]/mlink:scale-100 group-data-[active]/mlink:rotate-0"
                    aria-hidden="true"
                  >❧</span>
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
        <div
          class="mt-auto pt-12 text-center text-xl text-cherry-blossom-pink opacity-0 scale-[0.7] -rotate-[20deg] [transition:opacity_0.6s_ease_0.4s,transform_0.6s_cubic-bezier(0.34,1.56,0.64,1)_0.4s] group-[.is-open]/overlay:opacity-60 group-[.is-open]/overlay:scale-100 group-[.is-open]/overlay:rotate-0"
          aria-hidden="true"
        >
          ✾
        </div>
      </nav>
    </div>

    <div id="body" class="max-w-full p-2 desktop:p-8 gap-2 w-full container-grid">
      <p class="font-galnoy font-bold desktop:text-3xl hidden desktop:block col-start-2 col-span-1 row-span-2">
        Konstantin Kovar
      </p>
      <nav class="hidden desktop:block col-start-2 col-span-1 row-span-5">
        <ul class="list-none p-0 m-0 flex flex-col gap-1.5">
          {
            pages.map(({ label, href }) => (
              <li class="group/item relative" data-active={isActive(href) || undefined}>
                <a
                  href={href}
                  class="group/dlink flex items-center gap-0 whitespace-nowrap text-foreground no-underline py-2 px-3 rounded relative overflow-hidden [transition:color_0.4s_ease,background-color_0.4s_ease] before:content-[''] before:absolute before:bottom-0 before:left-3 before:right-3 before:h-px before:bg-foreground before:scale-x-0 before:origin-left before:[transition:transform_0.5s_cubic-bezier(0.22,1,0.36,1)] hover:before:scale-x-100 group-data-[active]/item:before:scale-x-100 after:content-[''] after:absolute after:inset-0 after:bg-foreground after:opacity-0 after:[transition:opacity_0.5s_ease] after:-z-10 after:rounded hover:after:opacity-[0.06] group-data-[active]/item:after:opacity-[0.08]"
                >
                  <span
                    class="inline-block w-0 overflow-hidden opacity-0 -rotate-90 scale-[0.6] [transition:width_0.4s_cubic-bezier(0.34,1.56,0.64,1),opacity_0.3s_ease,transform_0.4s_cubic-bezier(0.34,1.56,0.64,1)] text-cherry-blossom-pink shrink-0 group-hover/dlink:w-5 group-hover/dlink:opacity-100 group-hover/dlink:rotate-0 group-hover/dlink:scale-100 group-data-[active]/item:w-5 group-data-[active]/item:opacity-100 group-data-[active]/item:rotate-0 group-data-[active]/item:scale-100"
                    aria-hidden="true"
                  >❧</span>
                  <span class="[transition:transform_0.4s_cubic-bezier(0.22,1,0.36,1)] group-hover/dlink:translate-x-[2px]">
                    {label}
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      <div class="h-full row-span-full col-start-3"></div>
      <main
        class="grid grid-cols-subgrid col-start-1 desktop:col-start-4 -col-end-1 row-span-full"
      >
        <slot />
      </main>
      <div class="h-full row-span-full col-start-6"></div>
    </div>

    <script is:inline>
      const toggle = document.getElementById('nav-toggle');
      const overlay = document.getElementById('nav-overlay');
      let isOpen = false;

      function openNav() {
        isOpen = true;
        overlay.classList.add('is-open');
        toggle.classList.add('is-open');
        toggle.setAttribute('aria-expanded', 'true');
        toggle.setAttribute('aria-label', 'Navigation schließen');
        overlay.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }

      function closeNav() {
        isOpen = false;
        overlay.classList.remove('is-open');
        toggle.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'Navigation öffnen');
        overlay.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }

      toggle.addEventListener('click', () => isOpen ? closeNav() : openNav());
      document.getElementById('nav-backdrop').addEventListener('click', closeNav);
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && isOpen) closeNav(); });
    </script>

    <script
      is:inline
      data-goatcounter={GOATCOUNTER_URL}
      async
      src="//gc.zgo.at/count.js"></script>
  </body>
</html>

<style>
  @reference "../styles/app.css";

  .container-grid {
    @apply grid grid-cols-1 gap-0
           desktop:grid-cols-[0px_215px_80px_repeat(2,minmax(0px,385px))_80px_195px_0px] desktop:gap-6
           grid-rows-[4rem_repeat(5,3rem)_auto];
  }
</style>
