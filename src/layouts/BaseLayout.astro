---
import BaseHead from "../components/BaseHead.astro";
import { GOATCOUNTER_URL } from "../consts";
import {ColorModeToggle} from "../components/ColorModeToggle.tsx"
import {BubbleMenu} from "@/components/BubbleMenu.tsx"

type Props = {
  lang: "de" | "en";
  title: string;
  description?: string;
};

const pages: { label: string; href: string }[] = [
  { label: "Über mich", href: "/about" },
  { label: "Jüngst gelesen", href: "/book" },
  { label: "Jüngst geschrieben", href: "/blog" },
  { label: "RSS", href: "/rss.xml" },
];

const { lang, title, description } = Astro.props;
---

<script is:inline>
	const getThemePreference = () => {
		if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
			return localStorage.getItem('theme');
		}
		return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
	};
	const isDark = getThemePreference() === 'dark';
	document.documentElement.classList[isDark ? 'add' : 'remove']('dark');

	if (typeof localStorage !== 'undefined') {
		const observer = new MutationObserver(() => {
			const isDark = document.documentElement.classList.contains('dark');
			localStorage.setItem('theme', isDark ? 'dark' : 'light');
		});
		observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
	}
</script>


<!doctype html>
<html lang={lang}>
  <BaseHead title={title + " vom Konstantin"} description={description} />
  <body>
  <nav class="flex justify-end items-center p-4">
  <BubbleMenu
  containerClassName=""
     client:load
     items={pages}
     menuAriaLabel="Toggle navigation"
     useFixedPosition={false}
     animationEase="back.out(1.5)"
     animationDuration={0.5}
     staggerDelay={0.12}
   />          
</nav>

    <div id="body" class="max-w-full p-2 desktop:p-8 w-full desktop:flex desktop:gap-12">
      <div class="hidden desktop:block shrink-0 w-53.75">
        <p class="font-galnoy font-bold text-3xl mb-6">
          Konstantin Kovar
        </p>
      </div>
      <main class="min-w-0 flex-1">
      </main>
    </div>

    <script
      is:inline
      data-goatcounter={GOATCOUNTER_URL}
      async
      src="//gc.zgo.at/count.js"></script>
  </body>
</html>

